# Database
DB_USER=efms
DB_PASS=changeme
DB_NAME=efms_db

# Application secrets (replace before any non-local deploy)
JWT_SECRET=replace-with-a-random-string-at-least-32-chars

# Public URL the browser uses to reach the backend
# leave as-is for a local single-host deploy, set to the public URL when deploying remotely
API_URL=http://localhost:8080

# Host ports (change only if 3000 or 8080 are already taken)
FRONTEND_PORT=3000
BACKEND_PORT=8080

# Image tags, pin to a release tag for reproducible deploys
BACKEND_IMAGE=yonyc/efms-backend
FRONTEND_IMAGE=yonyc/efms-frontend
BACKEND_TAG=latest
FRONTEND_TAG=latest
